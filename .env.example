# icongener Application Environment Configuration

# ============================================
# Mistral AI Configuration
# ============================================
# Your Mistral AI API key for SVG generation
# Get your API key from: https://console.mistral.ai/
MISTRAL_API_KEY=dlgLJEL5033QHNmwpCHYHaT0iXlVq3bG

# ============================================
# Application Settings
# ============================================
# Environment mode (development, production, staging)
NODE_ENV=development

# Application port
PORT=3000

# Base URL for the application
BASE_URL=http://localhost:3000

# ============================================
# API Endpoints
# ============================================
# SVG generation endpoint
GENERATE_SVG_ENDPOINT=/api/generate-svg

# Preset enhancement endpoint
ENHANCE_PRESET_ENDPOINT=/api/enhance-preset

# ============================================
# File Upload Settings
# ============================================
# Maximum file upload size in bytes (default: 10MB)
MAX_FILE_SIZE=10485760

# Allowed file types for upload
ALLOWED_FILE_TYPES=image/png,image/jpeg,image/svg+xml

# ============================================
# Download Settings
# ============================================
# Default download directory
DOWNLOAD_DIR=./downloads

# ZIP compression level (0-9)
ZIP_COMPRESSION_LEVEL=6

# ============================================
# Progress Tracking
# ============================================
# Progress update interval in milliseconds
PROGRESS_INTERVAL=100

# ============================================
# Toast Notifications
# ============================================
# Toast auto-dismiss timeout in milliseconds
TOAST_TIMEOUT=3000

# Maximum number of toasts to show
MAX_TOASTS=5

# ============================================
# History Settings
# ============================================
# Maximum number of history items to store
MAX_HISTORY_ITEMS=50

# History storage key
HISTORY_STORAGE_KEY=history

# ============================================
# Settings
# ============================================
# Default language (en, sk)
DEFAULT_LANGUAGE=en

# Default theme (light, dark, system)
DEFAULT_THEME=dark

# Settings storage key
SETTINGS_STORAGE_KEY=settings

# ============================================
# Logging
# ============================================
# Enable debug logging (true, false)
DEBUG=false

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# ============================================
# Security
# ============================================
# Session secret (generate a random string)
SESSION_SECRET=your_random_session_secret_here

# CORS origin (for API)
CORS_ORIGIN=http://localhost:3000

# ============================================
# Notes:
# ============================================
# 1. Copy this file to .env and update the values
# 2. Never commit .env file to version control
# 3. .env file is in .gitignore
# 4. For production, use environment variables or secret management
# 5. Restart the application after changing .env values
